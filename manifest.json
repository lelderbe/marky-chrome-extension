{
  "manifest_version": 3,
  "name": "Marky",
  "version": "1.0.0",
  "description": "Добавляет текущую страницу в закладки с выбором папки",
  "permissions": ["bookmarks", "tabs"],
  "action": {
    "default_title": "Marky",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
